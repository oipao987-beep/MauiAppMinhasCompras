<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <VerticalStackLayout Padding="15" Spacing="15">

        <!-- SearchBar -->
        <SearchBar x:Name="searchBar"
                   Placeholder="Digite para buscar produtos..."
                   TextChanged="OnSearchTextChanged"
                   Margin="0,0,0,10"
                   HeightRequest="50" />
        
        <!-- Botão Produto -->
        <Button Text="➕ Novo Produto"
                Clicked="OnNovoClicked"
                BackgroundColor="#006400"
                TextColor="White"
                FontSize="18"
                HeightRequest="55"
                CornerRadius="8" />

        <!-- LISTA DE PRODUTOS + contexto no botão direito "Excluír" -->
        <!-- LISTA COM MENU DE CONTEXTO + clique para editar -->
        <ListView x:Name="lstProdutos"
          ItemsSource="{Binding .}"
          Margin="0,10,0,0"
          HeightRequest="400"
          HasUnevenRows="True"
          SelectionMode="None">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <!-- MENU BOTÃO DIREITO (Excluir) -->
                        <ViewCell.ContextActions>
                            <MenuItem Text="Excluir"
                              Clicked="OnExcluirClicked" 
                              IsDestructive="True" />
                        </ViewCell.ContextActions>

                        <!-- FRAME COM CLIQUE PARA EDITAR -->
                        <Frame Padding="10" Margin="0,5" CornerRadius="10" 
                       BackgroundColor="White" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnItemTapped" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="*, Auto, Auto">
                                <Label Text="{Binding Descricao}"
                               FontSize="Medium"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                                <Label Grid.Column="1"
                               Text="{Binding Quantidade, StringFormat='{0} un'}"
                               FontSize="Medium"
                               HorizontalOptions="End"
                               Margin="0,0,15,0"/>
                                <Label Grid.Column="2"
                               Text="{Binding Preco, StringFormat='{0:C}'}"
                               FontSize="Medium"
                               TextColor="#006400"
                               FontAttributes="Bold"/>
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- CARD VALOR TOTAL -->
        <Frame BackgroundColor="#006400" 
               CornerRadius="12" 
               Padding="20" 
               HasShadow="True">
            <VerticalStackLayout>
                <Label Text="VALOR TOTAL DAS COMPRAS" 
                       TextColor="White" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label x:Name="lblTotal" 
                       Text="R$ 0,00" 
                       TextColor="White" 
                       FontSize="28" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>