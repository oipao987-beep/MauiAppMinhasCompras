<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.MainPage"
             Title="Minhas Compras - Cadastro">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <Label Text="Cadastro de Produto" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Label Text="Nome do Produto" FontSize="16" />
            <Entry x:Name="txtNome" Placeholder="Ex: Arroz" />

            <Label Text="Quantidade" FontSize="16" />
            <Entry x:Name="txtQuantidade" 
                   Keyboard="Numeric" 
                   Placeholder="Ex: 5" />

            <Label Text="Preço Unitário (R$)" FontSize="16" />
            <Entry x:Name="txtPreco" 
                   Keyboard="Numeric" 
                   Placeholder="Ex: 8.99" />

            <Button Text="SALVAR NO SQLITE" 
                    Clicked="BtnSalvar_Clicked"
                    BackgroundColor="#006400"
                    TextColor="White"
                    FontSize="18"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>